# ─── Database ────────────────────────────────────────────────────────────────
# Connection string used by Prisma (with pgBouncer/pooler URL for serverless)
# Neon:    postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true
# Supabase: postgres://postgres:[password]@db.[ref].supabase.co:6543/postgres?pgbouncer=true
DATABASE_URL=

# Direct (non-pooled) URL — required by Prisma for migrations on Neon/Supabase
# Neon:    postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
# Supabase: postgres://postgres:[password]@db.[ref].supabase.co:5432/postgres
DIRECT_DATABASE_URL=

# ─── Redis ────────────────────────────────────────────────────────────────────
# Generic Redis URL (unused if Upstash REST vars are set)
REDIS_URL=

# Upstash Redis REST API — recommended for serverless/Vercel
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Sports data provider ─────────────────────────────────────────────────────
# API key for the external sports data provider (only needed when SPORTS_PROVIDER=real)
SPORTS_API_KEY=

# Base URL of the external sports data API (e.g. https://api.sportsdata.io/v3)
SPORTS_API_BASE_URL=

# Which provider to use: "mock" (reads from local DB) or "real" (calls external API)
SPORTS_PROVIDER=mock

# ─── Cron security ────────────────────────────────────────────────────────────
# Secret token that protects internal /api/sync/* endpoints from public access.
# Set the same value in Vercel > Project Settings > Environment Variables.
# Vercel Cron sends this automatically via the Authorization header.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# ─── App ──────────────────────────────────────────────────────────────────────
# Public URL of this deployment (used for absolute URL generation)
NEXT_PUBLIC_APP_URL=http://localhost:3000
