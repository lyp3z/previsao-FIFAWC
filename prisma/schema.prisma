generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

enum CompetitionStatus {
  SCHEDULED
  LIVE
  FINISHED
}

enum StageType {
  GROUP
  KNOCKOUT
  POSITIONAL
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum QualificationStatus {
  QUALIFIED
  PLAYOFF
  ELIMINATED
  TBD
}

model Competition {
  id             String            @id
  slug           String            @unique
  name           String
  year           Int
  official       Boolean           @default(true)
  hostCountries  String[]
  startDate      DateTime
  endDate        DateTime
  currentStageId String?
  status         CompetitionStatus @default(SCHEDULED)
  source         String
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  currentStage  Stage?       @relation("CurrentStage", fields: [currentStageId], references: [id])
  stages        Stage[]      @relation("CompetitionStages")
  groups        Group[]
  matches       Match[]
  standings     Standing[]
  knockout      KnockoutSlot[]
  teamStats     TeamStatsSnapshot[]
  projections   TeamTournamentProjection[]
  featureSets   MatchFeatureSet[]

  @@index([slug])
  @@index([year])
}

model Stage {
  id            String    @id
  competitionId String
  code          String
  name          String
  type          StageType
  order         Int
  isCurrent     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  competition             Competition   @relation("CompetitionStages", fields: [competitionId], references: [id], onDelete: Cascade)
  currentForCompetitions  Competition[] @relation("CurrentStage")
  matches                 Match[]
  standings               Standing[]
  knockoutSlots           KnockoutSlot[]

  @@unique([competitionId, code])
  @@index([competitionId, isCurrent])
  @@index([competitionId, order])
}

model Group {
  id            String   @id
  competitionId String
  code          String
  name          String
  order         Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  teams       Team[]
  matches     Match[]
  standings   Standing[]

  @@unique([competitionId, code])
  @@index([competitionId, order])
}

model Team {
  id            String   @id
  fifaId        String?
  name          String
  shortName     String
  code          String   @unique
  emoji         String
  flagUrl       String?
  confederation String?
  groupId       String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  group                 Group?       @relation(fields: [groupId], references: [id], onDelete: SetNull)
  homeMatches           Match[]      @relation("HomeTeam")
  awayMatches           Match[]      @relation("AwayTeam")
  winnerMatches         Match[]      @relation("WinnerTeam")
  standings             Standing[]
  homeKnockoutSlots     KnockoutSlot[] @relation("KnockoutHomeTeam")
  awayKnockoutSlots     KnockoutSlot[] @relation("KnockoutAwayTeam")
  winnerKnockoutSlots   KnockoutSlot[] @relation("KnockoutWinnerTeam")
  statsSnapshot         TeamStatsSnapshot?
  projections           TeamTournamentProjection[]
  homeFeatureSets       MatchFeatureSet[] @relation("FeatureHomeTeam")
  awayFeatureSets       MatchFeatureSet[] @relation("FeatureAwayTeam")

  @@index([groupId])
}

model Match {
  id               String      @id
  externalId       String?
  competitionId    String
  stageId          String
  groupId          String?
  roundLabel       String?
  matchNumber      Int?
  venue            String
  city             String
  country          String
  date             DateTime
  time             String
  datetimeUtc      DateTime
  timezone         String
  status           MatchStatus @default(SCHEDULED)
  isLive           Boolean     @default(false)
  minute           Int?
  homeTeamId       String
  awayTeamId       String
  homeScore        Int         @default(0)
  awayScore        Int         @default(0)
  homePenaltyScore Int?
  awayPenaltyScore Int?
  winnerTeamId     String?
  source           String
  sourceLastSync   DateTime?
  isOfficial       Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  competition    Competition       @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  stage          Stage             @relation(fields: [stageId], references: [id], onDelete: Cascade)
  group          Group?            @relation(fields: [groupId], references: [id], onDelete: SetNull)
  homeTeam       Team              @relation("HomeTeam", fields: [homeTeamId], references: [id], onDelete: Restrict)
  awayTeam       Team              @relation("AwayTeam", fields: [awayTeamId], references: [id], onDelete: Restrict)
  winnerTeam     Team?             @relation("WinnerTeam", fields: [winnerTeamId], references: [id], onDelete: SetNull)
  prediction     MatchPrediction?
  featureSet     MatchFeatureSet?
  odds           MatchOdds[]
  oddsSnapshots  OddsSnapshot[]
  bettingInsights BettingInsight[]

  @@index([competitionId, datetimeUtc])
  @@index([competitionId, stageId])
  @@index([competitionId, groupId])
  @@index([status, isLive])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model Standing {
  id                  String              @id
  competitionId       String
  stageId             String
  groupId             String
  teamId              String
  played              Int                 @default(0)
  wins                Int                 @default(0)
  draws               Int                 @default(0)
  losses              Int                 @default(0)
  goalsFor            Int                 @default(0)
  goalsAgainst        Int                 @default(0)
  goalDifference      Int                 @default(0)
  points              Int                 @default(0)
  position            Int                 @default(0)
  qualificationStatus QualificationStatus @default(TBD)
  updatedAt           DateTime            @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  stage       Stage       @relation(fields: [stageId], references: [id], onDelete: Cascade)
  group       Group       @relation(fields: [groupId], references: [id], onDelete: Cascade)
  team        Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([competitionId, stageId, groupId, teamId])
  @@index([competitionId, groupId, position])
  @@index([teamId])
}

model KnockoutSlot {
  id           String   @id
  competitionId String
  stageId      String
  slotCode     String
  label        String
  sourceRule   String
  homeTeamId   String?
  awayTeamId   String?
  winnerTeamId String?
  nextSlotCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  stage       Stage       @relation(fields: [stageId], references: [id], onDelete: Cascade)
  homeTeam    Team?       @relation("KnockoutHomeTeam", fields: [homeTeamId], references: [id], onDelete: SetNull)
  awayTeam    Team?       @relation("KnockoutAwayTeam", fields: [awayTeamId], references: [id], onDelete: SetNull)
  winnerTeam  Team?       @relation("KnockoutWinnerTeam", fields: [winnerTeamId], references: [id], onDelete: SetNull)

  @@unique([competitionId, slotCode])
  @@index([competitionId, stageId])
}

model SyncLog {
  id             String   @id @default(cuid())
  provider       String
  entityType     String
  startedAt      DateTime
  finishedAt     DateTime?
  success        Boolean
  message        String
  payloadSummary Json?

  @@index([entityType, startedAt])
}

model SimulationSession {
  id         String   @id @default(cuid())
  sessionKey String   @unique
  payload    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────────
//  Match Intelligence
// ─────────────────────────────────────────────────────────────

model TeamStatsSnapshot {
  id              String   @id @default(cuid())
  teamId          String   @unique
  competitionId   String
  matchesPlayed   Int      @default(0)
  wins            Int      @default(0)
  draws           Int      @default(0)
  losses          Int      @default(0)
  goalsFor        Int      @default(0)
  goalsAgainst    Int      @default(0)
  goalDifference  Int      @default(0)
  avgGoalsFor     Float    @default(0)
  avgGoalsAgainst Float    @default(0)
  cleanSheets     Int      @default(0)
  failedToScore   Int      @default(0)
  pointsPerMatch  Float    @default(0)
  recentFormScore Float    @default(0)
  attackStrength  Float    @default(1)
  defenseStrength Float    @default(1)
  updatedAt       DateTime @updatedAt

  team        Team        @relation(fields: [teamId], references: [id], onDelete: Cascade)
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)

  @@index([competitionId])
}

model MatchFeatureSet {
  id                    String   @id @default(cuid())
  matchId               String   @unique
  competitionId         String
  homeTeamId            String
  awayTeamId            String
  homeRecentForm        Float    @default(0)
  awayRecentForm        Float    @default(0)
  homeAttackStrength    Float    @default(1)
  awayAttackStrength    Float    @default(1)
  homeDefenseStrength   Float    @default(1)
  awayDefenseStrength   Float    @default(1)
  homeAvgGoalsFor       Float    @default(0)
  awayAvgGoalsFor       Float    @default(0)
  homeAvgGoalsAgainst   Float    @default(0)
  awayAvgGoalsAgainst   Float    @default(0)
  homePointsPerMatch    Float    @default(0)
  awayPointsPerMatch    Float    @default(0)
  stageWeight           Float    @default(1)
  isKnockout            Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  match       Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  homeTeam    Team        @relation("FeatureHomeTeam", fields: [homeTeamId], references: [id], onDelete: Cascade)
  awayTeam    Team        @relation("FeatureAwayTeam", fields: [awayTeamId], references: [id], onDelete: Cascade)

  @@index([competitionId])
}

// ─────────────────────────────────────────────────────────────
//  Probability Engine
// ─────────────────────────────────────────────────────────────

model PredictionModel {
  id          String   @id @default(cuid())
  name        String
  version     String
  description String
  isActive    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  predictions     MatchPrediction[]
  projections     TeamTournamentProjection[]
  bettingInsights BettingInsight[]

  @@unique([name, version])
}

model MatchPrediction {
  id                       String   @id @default(cuid())
  matchId                  String   @unique
  modelId                  String
  modelVersion             String
  homeWinProbability       Float
  drawProbability          Float
  awayWinProbability       Float
  over25Probability        Float?
  under25Probability       Float?
  bttsYesProbability       Float?
  bttsNoProbability        Float?
  toQualifyHomeProbability Float?
  toQualifyAwayProbability Float?
  confidenceScore          Float    @default(0)
  explanation              String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  match Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  model PredictionModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
}

model TeamTournamentProjection {
  id                            String   @id @default(cuid())
  teamId                        String
  competitionId                 String
  modelId                       String
  finishFirstProbability        Float    @default(0)
  finishSecondProbability       Float    @default(0)
  finishThirdProbability        Float    @default(0)
  reachRoundOf32Probability     Float    @default(0)
  reachRoundOf16Probability     Float    @default(0)
  reachQuarterFinalProbability  Float    @default(0)
  reachSemiFinalProbability     Float    @default(0)
  reachFinalProbability         Float    @default(0)
  winTournamentProbability      Float    @default(0)
  updatedAt                     DateTime @updatedAt

  team        Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  competition Competition     @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  model       PredictionModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([teamId, competitionId, modelId])
  @@index([competitionId, modelId])
}

// ─────────────────────────────────────────────────────────────
//  Odds Intelligence
// ─────────────────────────────────────────────────────────────

model Bookmaker {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  isSharp   Boolean?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  odds     MatchOdds[]
  insights BettingInsight[]
}

model Market {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  odds      MatchOdds[]
  snapshots OddsSnapshot[]
  insights  BettingInsight[]
}

model MatchOdds {
  id                 String   @id @default(cuid())
  matchId            String
  bookmakerId        String
  marketId           String
  selectionCode      String
  selectionLabel     String
  odd                Float
  line               Float?
  impliedProbability Float
  capturedAt         DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  match     Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  bookmaker Bookmaker @relation(fields: [bookmakerId], references: [id], onDelete: Cascade)
  market    Market    @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([matchId, marketId])
  @@index([matchId, bookmakerId])
  @@index([capturedAt])
}

model OddsSnapshot {
  id                        String   @id @default(cuid())
  matchId                   String
  marketId                  String
  selectionCode             String
  averageOdd                Float
  bestOdd                   Float
  lowestOdd                 Float
  averageImpliedProbability Float
  capturedAt                DateTime
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([matchId, marketId, capturedAt])
}

// ─────────────────────────────────────────────────────────────
//  Value Bet Engine
// ─────────────────────────────────────────────────────────────

model BettingInsight {
  id                 String   @id @default(cuid())
  matchId            String
  bookmakerId        String
  marketId           String
  modelId            String
  selectionCode      String
  modelProbability   Float
  impliedProbability Float
  fairOdd            Float
  offeredOdd         Float
  edge               Float
  expectedValue      Float
  confidenceScore    Float
  confidenceLabel    String
  isValueBet         Boolean  @default(false)
  explanation        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  match     Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  bookmaker Bookmaker       @relation(fields: [bookmakerId], references: [id], onDelete: Cascade)
  market    Market          @relation(fields: [marketId], references: [id], onDelete: Cascade)
  model     PredictionModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([isValueBet, expectedValue])
  @@index([modelId, createdAt])
}
